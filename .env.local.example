# 지도 provider: kakao | naver | custom (기본값 kakao)
NEXT_PUBLIC_MAP_PROVIDER=kakao

# Kakao Map JavaScript App Key (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_map_app_key

# Kakao REST API Key — geocoding 전용 (JavaScript 지도 키와 다름)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Naver Map JavaScript API v3 Client ID (https://www.ncloud.com)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_map_client_id

# Naver Geocoding API (REST, geocoding 전용)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Supabase (추후 연동용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
