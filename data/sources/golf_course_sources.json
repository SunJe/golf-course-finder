{
  "$schema": "./golf_course_sources.schema.json",
  "version": 1,
  "description": "골프장 데이터 source registry — master-first 병합 정책의 기준 파일",
  "roles": {
    "master": "전국 골프장 기본 목록의 기준",
    "supplement": "master에 매칭된 행만 자동 필드 보강",
    "candidate": "master에 없는 후보 — review 필요",
    "excluded": "일반 필드 골프장이 아님 — import 제외",
    "manual": "사용자 직접 보강 데이터"
  },
  "sources": [
    {
      "id": "ministry_national_golf_courses",
      "name": "문화체육관광부 전국 골프장 현황",
      "role": "master",
      "provider": "문화체육관광부 / 공공데이터포털",
      "expected_file_name": "ministry_golf_courses.csv",
      "download_status": "pending",
      "download_method": "manual_or_open_api",
      "requires_login": false,
      "requires_api_key": false,
      "expected_columns": [
        "업소명",
        "사업장명",
        "소재지",
        "도로명주소",
        "홀수",
        "구분",
        "운영구분"
      ],
      "trusted_fields": ["name", "address", "hole_count", "course_type"],
      "notes": "전국 골프장 master dataset의 1차 기준. 다른 source와 자동 병합하지 않는다."
    },
    {
      "id": "localdata_golf_courses",
      "name": "행정안전부 지역별 인허가 데이터 (골프장)",
      "role": "supplement",
      "provider": "행정안전부 / localdata",
      "expected_file_name": "localdata_golf_courses.csv",
      "download_status": "pending",
      "download_method": "open_api",
      "requires_login": false,
      "requires_api_key": true,
      "expected_columns": [
        "사업장명",
        "소재지",
        "도로명주소",
        "전화번호",
        "영업상태",
        "상세영업상태명"
      ],
      "trusted_fields": ["business_status", "phone", "address"],
      "notes": "master 행과 확실히 매칭될 때만 business_status, phone 보강."
    },
    {
      "id": "gyeonggi_golf_courses",
      "name": "경기도 골프장 현황",
      "role": "supplement",
      "provider": "경기도 / 지자체",
      "expected_file_name": "gyeonggi_golf_courses.csv",
      "download_status": "pending",
      "download_method": "manual",
      "requires_login": false,
      "requires_api_key": false,
      "expected_columns": [
        "시설명",
        "주소",
        "위도",
        "경도",
        "전화번호",
        "영업상태"
      ],
      "trusted_fields": [
        "latitude",
        "longitude",
        "phone",
        "business_status"
      ],
      "notes": "경기 지역 master 행 보강용. master에 없는 행은 candidate로 review."
    },
    {
      "id": "lx_spatial_golf_courses",
      "name": "LX 공간정보 / 좌표 보강 데이터",
      "role": "supplement",
      "provider": "LX / 공간정보",
      "expected_file_name": "lx_spatial_golf_courses.csv",
      "download_status": "pending",
      "download_method": "manual_or_api",
      "requires_login": true,
      "requires_api_key": false,
      "expected_columns": [
        "명칭",
        "주소",
        "X",
        "Y",
        "위도",
        "경도",
        "홀수"
      ],
      "trusted_fields": ["latitude", "longitude", "address", "hole_count"],
      "notes": "좌표계 확인 필요. WGS84가 아니면 임의 변환 금지. 불확실하면 review로 보낸다."
    },
    {
      "id": "manual_enrichment",
      "name": "수동 보강 데이터",
      "role": "manual",
      "provider": "GolfMap Korea 운영",
      "expected_file_name": "manual_course_enrichment.csv",
      "download_status": "pending",
      "download_method": "manual",
      "requires_login": false,
      "requires_api_key": false,
      "expected_columns": [
        "master_id",
        "name",
        "address",
        "homepage_url",
        "booking_url",
        "weekday_green_fee_min",
        "weekend_green_fee_min",
        "caddie_fee",
        "cart_fee",
        "night_round",
        "no_caddie",
        "two_player_allowed",
        "image_url",
        "description"
      ],
      "trusted_fields": [
        "homepage_url",
        "booking_url",
        "weekday_green_fee_min",
        "weekend_green_fee_min",
        "caddie_fee",
        "cart_fee",
        "night_round",
        "no_caddie",
        "two_player_allowed",
        "image_url",
        "description"
      ],
      "notes": "master_id 또는 name+address로 master 행에 매칭 후 수동 보강 필드만 반영."
    }
  ],
  "excluded_category_keywords": [
    "골프연습장",
    "연습장",
    "스크린골프",
    "스크린",
    "파크골프",
    "파크 골프",
    "골프 아카데미",
    "아카데미",
    "실내골프",
    "GDR",
    "골프존"
  ],
  "merge_policy_summary": {
    "master_first": true,
    "auto_merge_supplement_to_master_only": true,
    "auto_import_candidates": false,
    "auto_merge_on_name_only": false,
    "auto_merge_on_different_address": false,
    "final_import_requires_review_pass": true
  }
}
